# Copy file này thành .env rồi điền giá trị thật:  copy .env.example .env

# ── Database (MySQL) ─────────────────────────────────
# Format: mysql+aiomysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/ddk_ocr

# ── Security / JWT ───────────────────────────────────
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── First Admin (dùng cho scripts/create_admin.py) ───
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=Admin@123
FIRST_ADMIN_FULLNAME=System Administrator

# ── Scan / OCR ───────────────────────────────────────
# OCR_ENABLED=false  -> dùng MOCK OCR (chạy luồng, không cần model)
# OCR_ENABLED=true   -> dùng OCR thật theo OCR_PROVIDER
OCR_ENABLED=false
# OCR_PROVIDER=paddle    -> PaddleOCR chạy local (zone-based)
# OCR_PROVIDER=ocrspace  -> OCR.space API (so sánh)
OCR_PROVIDER=paddle
OCR_PREPROCESS_ENABLED=true
# Auto-rotate 0/90/180/270: tắt mặc định vì heuristic chưa tin cậy.
# Bật lại sau khi có cơ chế tốt hơn (PaddleOCR angle classifier toàn ảnh).
OCR_AUTO_ROTATE=false
OCR_DESKEW_ENABLED=true
OCR_TEMPLATE_ALIGN=true
SCAN_BATCH_MIN_FILES=1
SCAN_BATCH_MAX_FILES=5

# ── OCR debug & tuning ───────────────────────────────
# Bật OCR_DEBUG để lưu crop từng field + canvas vẽ box + log vào debug/<stem>/.
OCR_DEBUG=false
OCR_DEBUG_DIR=debug
OCR_PAD_X=15
OCR_PAD_Y=10
OCR_UPSCALE=2.0
OCR_EMPTY_FIELDS_THRESHOLD=0.70

# ── OCR.space (khi OCR_PROVIDER=ocrspace) ────────────
# Lấy API key tại https://ocr.space/ocrapi (free tier có giới hạn).
# Mặc định 'helloworld' chỉ chạy được vài request demo.
OCRSPACE_API_KEY=helloworld
OCRSPACE_LANGUAGE=cht
OCRSPACE_ENGINE=2
OCRSPACE_TIMEOUT=60

# ── PaddleOCR-VL (aistudio) — gọi API riêng, chưa wire vào pipeline ──
# Lấy token tại https://aistudio.baidu.com/ (sau đăng nhập).
PADDLEOCR_VL_TOKEN=
